# Makefile for SPARC (sparc-linux-gnu)

include mk/objects.mk

CC      = sparc-linux-gnu-gcc
CFLAGS  = -Wall -Wextra -Werror -pedantic -DMULTIPLE_SCORE_ENTRY -ansi
LDFLAGS = -lncursesw -ltinfow -lm

all: larn

larn: $(OBJS)
	$(CC) $(CFLAGS) $(OBJS) -o larn $(LDFLAGS)

%.o: %.c
	$(CC) $(CFLAGS) -c $< -o $@

clean:
	rm -f *.o larn
